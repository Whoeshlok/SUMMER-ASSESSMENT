ques 3635. Earliest Finish Time for Land and Water Rides II

class Solution {
public:
    int earliestFinishTime(vector<int>& landStartTime, vector<int>& landDuration, vector<int>& waterStartTime, vector<int>& waterDuration) {
        int ans = INT_MAX;
        int l = INT_MAX;
        int w = INT_MAX;
        for(int i = 0 ; i<landStartTime.size();i++){
            l = min(l,landStartTime[i] + landDuration[i]);
        }
        for(int i = 0 ; i<waterStartTime.size();i++){
            ans = min(ans,max(l,waterStartTime[i]) + waterDuration[i]);
        }
        for(int i = 0 ; i<waterStartTime.size();i++ ){
            w = min(w, waterStartTime[i]+ waterDuration[i]);
        }

        for(int i = 0 ; i<landStartTime.size();i++){
            ans = min(ans,max(w,landStartTime[i]) + landDuration[i]);
        }
        return ans;
    }
};


2390. Removing Stars From a String
solution :
class Solution {
public:
    string removeStars(string s) {
        stack<char>st;
        for(auto ch : s){
            if(!st.empty()){
                if(ch == '*') {
                    st.pop();
                    continue;
                }
            }
            st.push(ch);
        }
        string ans = "";
        while(!st.empty()){
            ans += st.top();
            st.pop();
        }
        reverse(ans.begin(),ans.end());
        return ans;
    }
};
